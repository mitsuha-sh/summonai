layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        children
    }
    tab name="interface" {
        pane borderless=true command="bash" {
            args "-c" "exec \"$SUMMONAI_ROOT/scripts/start-interface.sh\""
        }
    }
}
